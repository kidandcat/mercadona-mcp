# Mercadona account (https://tienda.mercadona.es)
# Prefer a refresh token when possible (headless, no captcha).

# Option A — refresh token (recommended)
# MERCADONA_REFRESH_TOKEN=

# Option B — one-shot access token
# MERCADONA_ACCESS_TOKEN=
# MERCADONA_CUSTOMER_ID=

# Option C — email + password (works today; may require captcha later)
MERCADONA_USER=
MERCADONA_PASS=

# Optional SQLite path (default: ~/.mercadona-mcp/data.db)
# DATABASE_PATH=
